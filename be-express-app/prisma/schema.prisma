generator client {
  provider = "prisma-client-js"
  output   = "../src/common/prisma/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model food {
  food_id     Int        @id @default(autoincrement())
  food_name   String?    @db.VarChar(150)
  image       String?    @db.VarChar(100)
  price       Float?     @db.Float
  description String?    @db.VarChar(255)
  is_deleted  Boolean    @default(false)
  type_id     Int?
  food_type   food_type? @relation(fields: [type_id], references: [type_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_food_foodtype")
  orders      orders[]
  sub_food    sub_food[]

  @@index([type_id], map: "fk_food_foodtype")
}

model food_type {
  type_id   Int     @id @default(autoincrement())
  type_name String? @db.VarChar(150)
  food      food[]
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model like_res {
  user_id    Int?
  res_id     Int?
  amount     Int?
  date_rate  DateTime?   @db.DateTime(0)
  restaurant restaurant? @relation(fields: [res_id], references: [res_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_like_res")
  users      users?      @relation(fields: [user_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_like_user")

  @@index([res_id], map: "fk_like_res")
  @@index([user_id], map: "fk_like_user")
  @@ignore
}

model orders {
  order_id   Int     @id @default(autoincrement())
  user_id    Int?
  food_id    Int?
  amount     Int?
  code       String? @db.VarChar(100)
  arr_sub_id String? @db.VarChar(100)
  food       food?   @relation(fields: [food_id], references: [food_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_food_id")
  users      users?  @relation(fields: [user_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_user_id")

  @@index([food_id], map: "fk_food_id")
  @@index([user_id], map: "fk_user_id")
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model rate_res {
  user_id    Int?
  res_id     Int?
  amount     Int?
  date_rate  DateTime?   @db.DateTime(0)
  restaurant restaurant? @relation(fields: [res_id], references: [res_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_rate_res")
  users      users?      @relation(fields: [user_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_rate_user")

  @@index([res_id], map: "fk_rate_res")
  @@index([user_id], map: "fk_rate_user")
  @@ignore
}

model restaurant {
  res_id      Int        @id @default(autoincrement())
  res_name    String?    @db.VarChar(150)
  image       String?    @db.VarChar(255)
  description String?    @db.VarChar(255)
  like_res    like_res[] @ignore
  rate_res    rate_res[] @ignore
}

model sub_food {
  sub_id    Int     @id @default(autoincrement())
  sub_name  String? @db.VarChar(150)
  sub_price Float?  @db.Float
  food_id   Int?
  food      food?   @relation(fields: [food_id], references: [food_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_subfood_food")

  @@index([food_id], map: "fk_subfood_food")
}

model users {
  user_id    Int        @id @default(autoincrement())
  full_name  String?    @db.VarChar(150)
  email      String?    @unique(map: "unique_email") @db.VarChar(100)
  password   String?    @db.VarChar(100)
  avatar     String?    @db.Text
  age        Int?
  totpSecret String?    @db.VarChar(255)
  googleId   String?    @db.VarChar(255)
  like_res   like_res[] @ignore
  orders     orders[]
  rate_res   rate_res[] @ignore
}
