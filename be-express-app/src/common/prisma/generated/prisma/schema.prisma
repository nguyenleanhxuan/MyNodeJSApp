generator client {
  provider = "prisma-client-js"
  output   = "../src/common/prisma/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model food {
  food_id     Int        @id @default(autoincrement())
  food_name   String?    @db.VarChar(150)
  image       String?    @db.VarChar(100)
  price       Float?     @db.Float
  description String?    @db.VarChar(255)
  is_deleted  Boolean    @default(false)
  type_id     Int?
  food_type   food_type? @relation(fields: [type_id], references: [type_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_food_foodtype")
  orders      orders[]
  sub_food    sub_food[]

  @@index([type_id], map: "fk_food_foodtype")
}

model food_type {
  type_id   Int     @id @default(autoincrement())
  type_name String? @db.VarChar(150)
  food      food[]
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model like_res {
  like_id    Int         @id @default(autoincrement())
  user_id    Int?
  res_id     Int?
  amount     Int?
  date_rate  DateTime?   @db.DateTime(0)
  restaurant restaurant? @relation(fields: [res_id], references: [res_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_like_res")
  users      users?      @relation(fields: [user_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_like_user")

  @@index([res_id], map: "fk_like_res")
  @@index([user_id], map: "fk_like_user")
}

model orders {
  order_id   Int     @id @default(autoincrement())
  user_id    Int?
  food_id    Int?
  amount     Int?
  code       String? @db.VarChar(100)
  arr_sub_id String? @db.VarChar(100)
  food       food?   @relation(fields: [food_id], references: [food_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_food_id")
  users      users?  @relation(fields: [user_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_user_id")

  @@index([food_id], map: "fk_food_id")
  @@index([user_id], map: "fk_user_id")
}

model rate_res {
  rate_id    Int        @id @default(autoincrement())
  user_id    Int
  res_id     Int
  amount     Int
  date_rate  DateTime   @default(now()) @db.DateTime(0)
  restaurant restaurant @relation(fields: [res_id], references: [res_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_rate_res")
  users      users      @relation(fields: [user_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_rate_user")

  @@unique([user_id, res_id], map: "uq_rate_user_restaurant")
  @@index([res_id], map: "fk_rate_res")
  @@index([user_id], map: "fk_rate_user")
}

model restaurant {
  res_id      Int        @id @default(autoincrement())
  res_name    String?    @db.VarChar(150)
  image       String?    @db.VarChar(255)
  description String?    @db.VarChar(255)
  like_res    like_res[]
  rate_res    rate_res[]
}

model sub_food {
  sub_id    Int     @id @default(autoincrement())
  sub_name  String? @db.VarChar(150)
  sub_price Float?  @db.Float
  food_id   Int?
  food      food?   @relation(fields: [food_id], references: [food_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_subfood_food")

  @@index([food_id], map: "fk_subfood_food")
}

model users {
  user_id          Int                @id @default(autoincrement())
  full_name        String?            @db.VarChar(150)
  email            String?            @unique(map: "unique_email") @db.VarChar(100)
  password         String?            @db.VarChar(100)
  avatar           String?            @db.Text
  age              Int?
  totpSecret       String?            @db.VarChar(255)
  googleId         String?            @db.VarChar(255)
  ChatGroupMembers ChatGroupMembers[]
  ChatGroups       ChatGroups[]
  ChatMessages     ChatMessages[]
  like_res         like_res[]
  orders           orders[]
  rate_res         rate_res[]
}

model ChatGroupMembers {
  id          Int         @id @default(autoincrement())
  userId      Int?
  chatGroupId Int?
  deletedBy   Int         @default(0)
  isDeleted   Boolean     @default(false)
  deletedAt   DateTime?   @db.Timestamp(0)
  createdAt   DateTime    @default(now()) @db.Timestamp(0)
  updatedAt   DateTime    @default(now()) @db.Timestamp(0)
  ChatGroups  ChatGroups? @relation(fields: [chatGroupId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_chat_group_members_group")
  users       users?      @relation(fields: [userId], references: [user_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_chat_group_members_user")

  @@index([chatGroupId], map: "fk_chat_group_members_group")
  @@index([userId], map: "fk_chat_group_members_user")
}

model ChatGroups {
  id               Int                @id @default(autoincrement())
  name             String?            @db.VarChar(255)
  ownerId          Int?
  deletedBy        Int                @default(0)
  isDeleted        Boolean            @default(false)
  deletedAt        DateTime?          @db.Timestamp(0)
  createdAt        DateTime           @default(now()) @db.Timestamp(0)
  updatedAt        DateTime           @default(now()) @db.Timestamp(0)
  ChatGroupMembers ChatGroupMembers[]
  users            users?             @relation(fields: [ownerId], references: [user_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_chat_groups_owner")
  ChatMessages     ChatMessages[]

  @@index([ownerId], map: "fk_chat_groups_owner")
}

model ChatMessages {
  id           Int         @id @default(autoincrement())
  chatGroupId  Int?
  userIdSender Int?
  messageText  String?     @db.Text
  deletedBy    Int         @default(0)
  isDeleted    Boolean     @default(false)
  deletedAt    DateTime?   @db.Timestamp(0)
  createdAt    DateTime    @default(now()) @db.Timestamp(0)
  updatedAt    DateTime    @default(now()) @db.Timestamp(0)
  ChatGroups   ChatGroups? @relation(fields: [chatGroupId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_chat_messages_group")
  users        users?      @relation(fields: [userIdSender], references: [user_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_chat_messages_sender")

  @@index([chatGroupId], map: "fk_chat_messages_group")
  @@index([userIdSender], map: "fk_chat_messages_sender")
}
